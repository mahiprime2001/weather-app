# Copy this file to ".env" and adjust as you like. All values are optional.

# Units: "metric" (°C, km/h) or "imperial" (°F, mph)
WEATHER_UNITS=metric

# City used when you don't pass one on the command line
WEATHER_DEFAULT_CITY=London

# Seconds to reuse a cached API response before refetching (0 disables caching)
WEATHER_CACHE_TTL=600

# Where cached responses are stored (defaults to ~/.weather-app/cache)
# WEATHER_CACHE_DIR=/path/to/cache

# Open-Meteo needs no key. This slot exists for switching to a keyed provider.
# WEATHER_API_KEY=your-key-here
